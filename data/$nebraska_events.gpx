    <desc>CITO McEvoy Adopt-A-Road Spring '26 by LadyCache, Cache In Trash Out Event (1.0/1.5)</desc>
    <url>https://coord.info/GCBJPWM</url>
    <urlname>CITO McEvoy Adopt-A-Road Spring '26</urlname>
    <sym>Geocache</sym>
    <type>Geocache|Cache In Trash Out Event</type>
    <groundspeak:cache id="10305848" archived="False" available="True" xmlns:groundspeak="http://www.groundspeak.com/cache/1/0/1">
      <groundspeak:name>CITO McEvoy Adopt-A-Road Spring '26</groundspeak:name>
      <groundspeak:placed_by>LadyCache</groundspeak:placed_by>
      <groundspeak:owner id="568858">LadyCache</groundspeak:owner>
      <groundspeak:type>Cache In Trash Out Event</groundspeak:type>
      <groundspeak:container>Other</groundspeak:container>
      <groundspeak:attributes>
        <groundspeak:attribute id="6" inc="1">Recommended for kids</groundspeak:attribute>
        <groundspeak:attribute id="41" inc="1">Stroller accessible</groundspeak:attribute>
        <groundspeak:attribute id="1" inc="1">Dogs</groundspeak:attribute>
        <groundspeak:attribute id="25" inc="1">Parking nearby</groundspeak:attribute>
        <groundspeak:attribute id="27" inc="1">Drinking water nearby</groundspeak:attribute>
      </groundspeak:attributes>
      <groundspeak:difficulty>1.0</groundspeak:difficulty>
      <groundspeak:terrain>1.5</groundspeak:terrain>
      <groundspeak:country>United States</groundspeak:country>
      <groundspeak:state>Nebraska</groundspeak:state>
      <groundspeak:short_description html="True">&lt;b&gt;21 March 2026, 08:30 - 09:30&lt;/b&gt;</groundspeak:short_description>
      <groundspeak:long_description html="True">&lt;p&gt;&lt;strong&gt;21 March 2026, 08:30 am - 9:30 am&lt;/strong&gt;&lt;/p&gt;

&lt;p&gt; &lt;/p&gt;

&lt;h1 style="text-align:center;"&gt;&lt;strong&gt;&lt;span style="background-color:#2ecc71;"&gt;CITO   CITO   CITO   CITO   CITO   CITO&lt;/span&gt;&lt;/strong&gt;&lt;/h1&gt;

&lt;p&gt; &lt;/p&gt;

&lt;p&gt;&lt;strong&gt;Come join the fun of picking up trash along 36th Street between Highway 370 and Capehart Road.&lt;/strong&gt;&lt;/p&gt;

&lt;p&gt;We will meet at the posted coordinated in the parking lot at St Matthews Church for instructions and bags.  Please bring any gloves and pick up tools you prefer.  &lt;/p&gt;

&lt;p style="text-align:center;"&gt;&lt;strong&gt;I will bring some water.  &lt;/strong&gt;&lt;br /&gt;
&lt;strong&gt;However, you may also want to bring some water along too.&lt;/strong&gt; &lt;/p&gt;

&lt;p&gt;This stretch of road has paved sidewalks on both sides of the road in most places. Children must be under supervision of an adult for obvious safety precautions. &lt;/p&gt;

&lt;p&gt;After instructions, the group can split up and I can shuttle cachers to the ends for the walk back to the parking lot. &lt;/p&gt;

&lt;p&gt; &lt;/p&gt;

&lt;h2 style="text-align:center;"&gt;&lt;span style="color:#2ecc71;"&gt;&lt;strong&gt;Group pictures at end of event.&lt;/strong&gt;&lt;/span&gt;&lt;/h2&gt;

&lt;p&gt; &lt;/p&gt;

&lt;p&gt;&lt;em&gt;The McEvoy family has had this stretch of adopt-a-road since 1999, with just one family member able to continue this great service.  I know he will appreciate us geocachers to participate with him.&lt;/em&gt;&lt;/p&gt;

&lt;p&gt; &lt;/p&gt;

&lt;h2 style="text-align:center;"&gt;&lt;strong&gt;&lt;span style="background-color:#2ecc71;"&gt;Get your 2026 Season 1 CITO Souvenir.&lt;/span&gt;&lt;/strong&gt;&lt;/h2&gt;

&lt;p style="text-align:center;"&gt;&lt;img src="https://img.geocaching.com/eb86c82a-4088-4f54-9dab-ead2d30bb5dc.png" /&gt;&lt;/p&gt;

&lt;p style="text-align:center;"&gt; &lt;/p&gt;

&lt;p style="text-align:center;"&gt;&lt;a href="http://nebraskache.com/"&gt;&lt;img height="112" src="https://img.geocaching.com/9102f957-c986-41b5-acdb-a076bd017129.jpg" width="224" /&gt;&lt;/a&gt;&lt;/p&gt;

&lt;p style="text-align:center;"&gt;&lt;a href="http://nebraskache.com/"&gt;Hosted By A Nebraskache Member&lt;/a&gt;&lt;/p&gt;

&lt;p style="text-align:center;"&gt;&lt;a href="https://www.facebook.com/groups/107321656812/"&gt;&lt;img height="68" src="https://s3.amazonaws.com/gs-geo-images/19b6196d-f1d8-431b-9201-f4069d107ada_l.png" width="213" /&gt;&lt;/a&gt;&lt;/p&gt;

&lt;p style="text-align:center;"&gt;As the geocache event owner, I ensure that these links to a local geocaching group that is active in the community and contributing to geocaching in positive ways. This link has not been checked by Geocaching HQ or by the reviewer.&lt;/p&gt;

&lt;p&gt; &lt;/p&gt;
</groundspeak:long_description>

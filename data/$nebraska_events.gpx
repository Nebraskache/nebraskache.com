  <wpt lat="40.680167" lon="-99.083917">
    <time>2026-04-11T09:00:00</time>
    <name>GCBM070</name>
    <desc>Breakfast in the Tri-Cities Kearney by Jerry+Mary, Event Cache (1.0/1.0)</desc>
    <url>https://coord.info/GCBM070</url>
    <urlname>Breakfast in the Tri-Cities Kearney</urlname>
    <sym>Geocache</sym>
    <type>Geocache|Event Cache</type>
    <groundspeak:cache id="10343648" archived="False" available="True" xmlns:groundspeak="http://www.groundspeak.com/cache/1/0/1">
      <groundspeak:name>Breakfast in the Tri-Cities Kearney</groundspeak:name>
      <groundspeak:placed_by>Jerry+Mary</groundspeak:placed_by>
      <groundspeak:owner id="4044933">Jerry+Mary</groundspeak:owner>
      <groundspeak:type>Event Cache</groundspeak:type>
      <groundspeak:container>Other</groundspeak:container>
      <groundspeak:attributes>
        <groundspeak:attribute id="24" inc="1">Wheelchair accessible</groundspeak:attribute>
        <groundspeak:attribute id="25" inc="1">Parking nearby</groundspeak:attribute>
        <groundspeak:attribute id="66" inc="1">Teamwork cache</groundspeak:attribute>
        <groundspeak:attribute id="63" inc="1">Recommended for tourists</groundspeak:attribute>
        <groundspeak:attribute id="28" inc="1">Public restrooms nearby</groundspeak:attribute>
        <groundspeak:attribute id="59" inc="1">Food nearby</groundspeak:attribute>
        <groundspeak:attribute id="27" inc="1">Drinking water nearby</groundspeak:attribute>
      </groundspeak:attributes>
      <groundspeak:difficulty>1.0</groundspeak:difficulty>
      <groundspeak:terrain>1.0</groundspeak:terrain>
      <groundspeak:country>United States</groundspeak:country>
      <groundspeak:state>Nebraska</groundspeak:state>
      <groundspeak:short_description html="True">&lt;b&gt;11 April 2026, 09:00 - 10:00&lt;/b&gt;</groundspeak:short_description>
      <groundspeak:long_description html="True">&lt;p&gt;&lt;strong&gt;You are invited to attend our monthly geocaching breakfast event.&amp;nbsp; Since the Lodge closed we are going to try Perkins Restaurant again.&amp;nbsp; We&amp;#39;re hoping the food and service are good.&amp;nbsp; We have reservations for the back room.&amp;nbsp; Come share your stories and enjoy some comaraderie with your fellow Geocachers.&amp;nbsp; You might even get some help with that hard hide or puzzle.&lt;/strong&gt;&lt;/p&gt;

&lt;p&gt;&lt;big&gt;Where:&amp;nbsp; Perkins Restaurant&lt;/big&gt;&lt;br /&gt;
609 2nd Avenue&lt;br /&gt;
Kearney&amp;nbsp;NE&lt;br /&gt;
Date: April 11, 2026&lt;br /&gt;
Time: 9:00 A.M. - 10:00 AM&lt;/p&gt;

&lt;p&gt;All ages and all cachers are invited. You can eat. You can drink. You can eat and drink. You can do neither and just show up to chat (no purchase necessary to attend).&amp;nbsp;&amp;nbsp;There is no meeting or agenda - just come and visit and do some geo-socializing with other geocachers. Hope to see you there! Please bring your coins and TBs for discovery, and for everyone else to enjoy!!&lt;/p&gt;

&lt;p&gt;&lt;strong&gt;Please post a will attend so I can gi&lt;/strong&gt;&lt;strong&gt;ve the restaurant a heads up as to how many people will be there.&lt;/strong&gt;&lt;/p&gt;

&lt;p&gt;&amp;nbsp;&lt;/p&gt;

&lt;p style="text-align:center"&gt;&lt;a href="http://nebraskache.com/"&gt;&lt;img height="112" src="https://img.geocaching.com/9102f957-c986-41b5-acdb-a076bd017129.jpg" width="224" /&gt;&lt;/a&gt;&lt;/p&gt;

&lt;p style="text-align:center"&gt;&lt;a href="http://nebraskache.com/"&gt;Hosted By Nebraskache&lt;/a&gt;&lt;/p&gt;

&lt;p style="text-align:center"&gt;&lt;a href="https://www.facebook.com/groups/107321656812/"&gt;&lt;img height="70" src="https://s3.amazonaws.com/gs-geo-images/19b6196d-f1d8-431b-9201-f4069d107ada_l.png" width="230" /&gt;&lt;/a&gt;&lt;/p&gt;

&lt;p&gt;As the geocache event owner, I ensure that these links to a local geocaching group that is active in the community and contributing to geocaching in positive ways. This link has not been checked by Geocaching HQ or by the reviewer.&lt;/p&gt;
</groundspeak:long_description>

      <groundspeak:terrain>1.0</groundspeak:terrain>
      <groundspeak:country>United States</groundspeak:country>
      <groundspeak:state>Nebraska</groundspeak:state>
      <groundspeak:short_description html="True">&lt;b&gt;11 July 2026, 08:00 - 09:30&lt;/b&gt;</groundspeak:short_description>
      <groundspeak:long_description html="True">&lt;p&gt;&lt;strong&gt;Jully 11th 0800-0930&lt;/strong&gt;&lt;/p&gt;

&lt;p&gt;Please join your fellow cachers for the monthly Deli Caching Breakfast.  This is a monthly event so you all know where to go.&lt;/p&gt;

&lt;p&gt;The deli is wheelchair accessible and offers three options:&lt;/p&gt;

&lt;p&gt;1.  a full breakfast and lunch menu&lt;/p&gt;

&lt;p&gt;2.  purchase something (like a donut or yogurt) from the store and enjoy it at the event&lt;/p&gt;

&lt;p&gt;3.  just join us for the fun.  No purchase is necessary to attend this event.&lt;/p&gt;
</groundspeak:long_description>

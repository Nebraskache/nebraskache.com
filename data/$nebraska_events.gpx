      <groundspeak:short_description html="True">&lt;b&gt;28 February 2026, 09:15 - 10:15&lt;/b&gt;</groundspeak:short_description>
      <groundspeak:long_description html="True">&lt;p&gt;&lt;span style="font-size:12.0pt"&gt;&lt;span style="font-family:&amp;quot;Times New Roman&amp;quot;,serif"&gt;Come enjoy a friendly cup of coffee on a Sunday morning with geocaching friends in Midtown Crossing.&amp;nbsp; The coffee shop is Spielbound.&amp;nbsp; No purchase necessary.&amp;nbsp; The street address is 3229 Harney St., Omaha, NE 68131.&amp;nbsp; There is on-street parking on Harney and a parking garage across Harney from the coffee shop.&amp;nbsp; See you there.&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;
&lt;p&gt;Additional Waypoints&lt;/p&gt;P0BJ14D - Parking Garage&lt;br /&gt;N 41° 15.408 W 095° 57.650&lt;br /&gt;The first two hours in the garage are free.&lt;br /&gt;</groundspeak:long_description>

        <groundspeak:log id="1357159227">
          <groundspeak:date>2026-04-25T22:07:39Z</groundspeak:date>
          <groundspeak:type>Attended</groundspeak:type>
          <groundspeak:finder id="49030438">ehuertv536</groundspeak:finder>
          <groundspeak:text encoded="False">First Geocache Event attended - loved meeting fellow geocachers  and learning about creating caches!  - thanks J&amp;LA for hosting this event!</groundspeak:text>

    <groundspeak:cache id="10263501" archived="False" available="True" xmlns:groundspeak="http://www.groundspeak.com/cache/1/0/1">
      <groundspeak:name>Join Us for a Cup of Joe - June 2026</groundspeak:name>
      <groundspeak:placed_by>Northeast Nebraska Geocachers</groundspeak:placed_by>
      <groundspeak:owner id="3067478">JavaJudt</groundspeak:owner>
      <groundspeak:type>Event Cache</groundspeak:type>
      <groundspeak:container>Other</groundspeak:container>
      <groundspeak:attributes>
        <groundspeak:attribute id="24" inc="1">Wheelchair accessible</groundspeak:attribute>
        <groundspeak:attribute id="6" inc="1">Recommended for kids</groundspeak:attribute>
        <groundspeak:attribute id="41" inc="1">Stroller accessible</groundspeak:attribute>
        <groundspeak:attribute id="1" inc="0">Dogs</groundspeak:attribute>
        <groundspeak:attribute id="8" inc="0">Scenic view</groundspeak:attribute>
        <groundspeak:attribute id="32" inc="1">Bicycles</groundspeak:attribute>
        <groundspeak:attribute id="63" inc="1">Recommended for tourists</groundspeak:attribute>
        <groundspeak:attribute id="30" inc="1">Picnic tables nearby</groundspeak:attribute>
        <groundspeak:attribute id="28" inc="1">Public restrooms nearby</groundspeak:attribute>
        <groundspeak:attribute id="59" inc="1">Food nearby</groundspeak:attribute>
        <groundspeak:attribute id="27" inc="1">Drinking water nearby</groundspeak:attribute>
        <groundspeak:attribute id="33" inc="1">Motorcycles</groundspeak:attribute>
        <groundspeak:attribute id="37" inc="0">Horses</groundspeak:attribute>
        <groundspeak:attribute id="31" inc="0">Camping nearby</groundspeak:attribute>
        <groundspeak:attribute id="38" inc="0">Campfires</groundspeak:attribute>
      </groundspeak:attributes>
      <groundspeak:difficulty>1.0</groundspeak:difficulty>
      <groundspeak:terrain>1.0</groundspeak:terrain>
      <groundspeak:country>United States</groundspeak:country>
      <groundspeak:state>Nebraska</groundspeak:state>
      <groundspeak:short_description html="True">&lt;b&gt;20 June 2026, 10:00 - 11:00&lt;/b&gt;</groundspeak:short_description>
      <groundspeak:long_description html="True">&lt;h1 style="text-align:center;"&gt;&lt;span style="color:#8e44ad;"&gt;Come join the Northeast Nebraska Geocachers for a Cup of Joe&lt;/span&gt;&lt;/h1&gt;

&lt;p&gt; &lt;/p&gt;

&lt;h1 style="text-align:center;"&gt;&lt;span style="color:#8e44ad;"&gt;June 2026&lt;/span&gt;&lt;/h1&gt;

&lt;p&gt; &lt;/p&gt;

&lt;p style="text-align:center;"&gt;&lt;img src="https://s3.amazonaws.com/gs-geo-images/f35dd082-e8d1-4243-bc06-d60895ee5c45_l.jpg" width="350" /&gt;&lt;/p&gt;

&lt;h3 style="text-align:center;"&gt; &lt;/h3&gt;

&lt;p style="text-align:center;"&gt;Please come and “Join Us for a Cup of Joe” to share caching adventures, misadventures, and what ever else you care to share. Whether you are a caching veteran or are new to the madness, bring your stories, questions, and expertise, and let&amp;#39;s have some fun!&lt;/p&gt;

&lt;p style="text-align:center;"&gt;This is a monthly recurring event in Norfolk. The event is typically held mid-late morning on the last Saturday of the month, and rotates around to various eateries in town. Events are a great way to meet other geocachers, and if you are new, to have your questions answered. Come on out, we don&amp;#39;t bite!&lt;/p&gt;

&lt;p style="text-align:center;"&gt;&lt;span style="color:#660033;"&gt;This month&amp;#39;s event will run from &lt;/span&gt;&lt;span style="color:#e74c3c;"&gt;10:00 am - 11:00 am &lt;/span&gt;&lt;span style="color:#660033;"&gt;and take place at &amp;quot;Fenders&amp;quot; in Norfolk, NE. June&amp;#39;s event is a week earlier than normal.&lt;/span&gt;&lt;/p&gt;

&lt;p style="text-align:center;"&gt;There is an assortment of goodies available, but no purchase is required to join in the fun. Please try to let us know in advance if you plan to be there by posting a &amp;quot;Will Attend&amp;quot;. This helps us plan accordingly, but feel free to &amp;quot;just show up&amp;quot; as well! We&amp;#39;ll have a chair for you.&lt;/p&gt;

&lt;p style="text-align:center;"&gt; &lt;/p&gt;

&lt;h2 style="text-align:center;"&gt;&lt;span style="color:#c0392b;"&gt;Hope to see you there!&lt;/span&gt;&lt;/h2&gt;

&lt;p style="text-align:center;"&gt; &lt;/p&gt;

&lt;p style="text-align:center;"&gt;&lt;img alt="Nebraskache Logo" src="https://img.geocaching.com/02df206f-732a-4144-9c3d-582344cf4638.jpg" style="height:95px;width:190px;" /&gt;&lt;/p&gt;

&lt;p style="text-align:center;"&gt; &lt;/p&gt;
</groundspeak:long_description>

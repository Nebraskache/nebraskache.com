          <groundspeak:date>2026-05-02T19:00:00Z</groundspeak:date>
          <groundspeak:type>Attended</groundspeak:type>
          <groundspeak:finder id="7098330">cwalford2</groundspeak:finder>
          <groundspeak:text encoded="False">Great event and thanks for the donuts</groundspeak:text>

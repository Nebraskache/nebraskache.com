    <name>GCBPG6F</name>
    <desc>Lunch for a Little Cache Redux #59 by peteach!, Event Cache (1.0/1.0)</desc>
    <url>https://coord.info/GCBPG6F</url>
    <urlname>Lunch for a Little Cache Redux #59</urlname>
    <sym>Geocache</sym>
    <type>Geocache|Event Cache</type>
    <groundspeak:cache id="10418590" archived="False" available="True" xmlns:groundspeak="http://www.groundspeak.com/cache/1/0/1">
      <groundspeak:name>Lunch for a Little Cache Redux #59</groundspeak:name>
      <groundspeak:placed_by>peteach! And starsharon </groundspeak:placed_by>
      <groundspeak:owner id="5787200">peteach!</groundspeak:owner>
      <groundspeak:type>Event Cache</groundspeak:type>
      <groundspeak:container>Other</groundspeak:container>
      <groundspeak:attributes>
        <groundspeak:attribute id="24" inc="1">Wheelchair accessible</groundspeak:attribute>
        <groundspeak:attribute id="25" inc="1">Parking nearby</groundspeak:attribute>
        <groundspeak:attribute id="63" inc="1">Recommended for tourists</groundspeak:attribute>
        <groundspeak:attribute id="28" inc="1">Public restrooms nearby</groundspeak:attribute>
        <groundspeak:attribute id="59" inc="1">Food nearby</groundspeak:attribute>
        <groundspeak:attribute id="27" inc="1">Drinking water nearby</groundspeak:attribute>
        <groundspeak:attribute id="29" inc="1">Telephone nearby</groundspeak:attribute>
      </groundspeak:attributes>
      <groundspeak:difficulty>1.0</groundspeak:difficulty>
      <groundspeak:terrain>1.0</groundspeak:terrain>
      <groundspeak:country>United States</groundspeak:country>
      <groundspeak:state>Nebraska</groundspeak:state>
      <groundspeak:short_description html="True">&lt;b&gt;04 June 2026, 11:45 - 13:00&lt;/b&gt;</groundspeak:short_description>
      <groundspeak:long_description html="True">&lt;p&gt;A recurring monthly Geocaching Event in Lincoln, open to everyone. Local and out-of-town geocachers are welcome and encouraged to attend.&amp;nbsp;&lt;/p&gt;

&lt;p&gt;Come join starsharon and peteach! and the regular attendees for lunch. We will rotate host duties on the first Thursday of almost every month. We may also throw in a guest host once in a while. This will be a great opportunity to plan a weekend geocaching trip with other attendees, ask for help on those caches that are driving you crazy, trade/share Travel Bugs and/or other trackable items, or just have a nice lunch and trade geocaching stories.&lt;/p&gt;

&lt;p&gt;Location: Stauffer&amp;rsquo;s Caf&amp;eacute;. 5600 South 48th Street. (between Old Cheney and hwy 2 on 48th)&lt;/p&gt;

&lt;p&gt;Time: Thursday, June 4, 2026, 11:45 a.m. to 1:00-ish (CST).&lt;/p&gt;

&lt;p&gt;PLEASE, provide a &amp;ldquo;Will Attend&amp;rdquo; log so we can get a head-count for the caf&amp;eacute;. If we have 9 or more, we will get a private party room....8 or fewer, and we will be at a large table.&lt;/p&gt;

&lt;p&gt;This location has a full menu for those who would like to eat lunch (or breakfast) with us, but no purchase is necessary to attend the event. We hope to see you there.&lt;/p&gt;
</groundspeak:long_description>
      <groundspeak:encoded_hints>
      </groundspeak:encoded_hints>

    <desc>Let's EAT! - CXLVII (147) - May Flowers by LadyGunslinger, Event Cache (1.0/1.0)</desc>
    <url>https://coord.info/GCBP15G</url>
    <urlname>Let's EAT! - CXLVII (147) - May Flowers</urlname>
    <sym>Geocache</sym>
    <type>Geocache|Event Cache</type>
    <groundspeak:cache id="10404145" archived="False" available="True" xmlns:groundspeak="http://www.groundspeak.com/cache/1/0/1">
      <groundspeak:name>Let's EAT! - CXLVII (147) - May Flowers</groundspeak:name>
      <groundspeak:placed_by>LadyGunslinger</groundspeak:placed_by>
      <groundspeak:owner id="841414">LadyGunslinger</groundspeak:owner>

    <groundspeak:cache id="10397577" archived="False" available="True" xmlns:groundspeak="http://www.groundspeak.com/cache/1/0/1">
      <groundspeak:name>23rd Annual Nebraskache Picnic</groundspeak:name>
      <groundspeak:placed_by>Nebraskache</groundspeak:placed_by>
      <groundspeak:owner id="157466">Nebraskache</groundspeak:owner>
      <groundspeak:type>Event Cache</groundspeak:type>

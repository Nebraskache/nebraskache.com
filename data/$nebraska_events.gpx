  <wpt lat="42.041864" lon="-97.444622">
    <time>2026-06-03T19:30:00</time>
    <name>GCBM1CK</name>
    <desc>Stars, Strolls &amp; Smores - an intro to Geocaching by Visit Norfolk NE, Event Cache (1.0/1.5)</desc>
    <url>https://coord.info/GCBM1CK</url>
    <urlname>Stars, Strolls &amp; Smores - an intro to Geocaching</urlname>
    <sym>Geocache</sym>
    <type>Geocache|Event Cache</type>
    <groundspeak:cache id="10344783" archived="False" available="True" xmlns:groundspeak="http://www.groundspeak.com/cache/1/0/1">
      <groundspeak:name>Stars, Strolls &amp; Smores - an intro to Geocaching</groundspeak:name>
      <groundspeak:placed_by>Visit Norfolk NE</groundspeak:placed_by>
      <groundspeak:owner id="5507730">Visit Norfolk NE</groundspeak:owner>
      <groundspeak:type>Event Cache</groundspeak:type>
      <groundspeak:container>Other</groundspeak:container>
      <groundspeak:attributes>
        <groundspeak:attribute id="6" inc="1">Recommended for kids</groundspeak:attribute>
        <groundspeak:attribute id="41" inc="1">Stroller accessible</groundspeak:attribute>
        <groundspeak:attribute id="1" inc="1">Dogs</groundspeak:attribute>
        <groundspeak:attribute id="32" inc="1">Bicycles</groundspeak:attribute>
        <groundspeak:attribute id="55" inc="1">Short hike (&lt;1 km)</groundspeak:attribute>
        <groundspeak:attribute id="30" inc="1">Picnic tables nearby</groundspeak:attribute>
        <groundspeak:attribute id="28" inc="1">Public restrooms nearby</groundspeak:attribute>
        <groundspeak:attribute id="59" inc="1">Food nearby</groundspeak:attribute>
      </groundspeak:attributes>
      <groundspeak:difficulty>1.0</groundspeak:difficulty>
      <groundspeak:terrain>1.5</groundspeak:terrain>
      <groundspeak:country>United States</groundspeak:country>
      <groundspeak:state>Nebraska</groundspeak:state>
      <groundspeak:short_description html="True">&lt;b&gt;03 June 2026, 19:30 - 21:00&lt;/b&gt;</groundspeak:short_description>
      <groundspeak:long_description html="True">&lt;p&gt;Join us for an exciting, family-friendly night with nature while we learn about the outdoors and some fun outdoor activities!&lt;/p&gt;

&lt;p&gt;For June&amp;#39;s activity this year, we are bringing back Geocaching! We&amp;#39;ll have a local expert in Geocaching introduce the hobby and present on how to get started. If time allows, we&amp;#39;ll go for a short walk to see some examples of geocache hides you may come across.&lt;/p&gt;

&lt;p&gt;We&amp;#39;ll meet near the west park entrance fishing dock. There is parking nearby at the parking lot off of 25th Street.&lt;/p&gt;

&lt;p&gt;This event is completely FREE, with s&amp;#39;mores provided after the presentations!&lt;/p&gt;

&lt;p&gt;In addition to Geocaching, we will also have a presentation on catfishing tonight. There may be a third presentation - we are still working on nailing down the topic.&lt;/p&gt;

&lt;p&gt;Please dress for the weather. We recommend dressing in layers as the temperature at the lake may be colder than it is in town, especially as the sun goes down. Bring bug spray and water. Most of all, be ready for a night of fun!&lt;/p&gt;
</groundspeak:long_description>
      <groundspeak:encoded_hints>
      </groundspeak:encoded_hints>
      <groundspeak:logs>
        <groundspeak:log id="1365189810">
          <groundspeak:date>2026-06-04T04:53:27Z</groundspeak:date>
          <groundspeak:type>Attended</groundspeak:type>
          <groundspeak:finder id="24656515">CheeseBurgerUnicorn</groundspeak:finder>
          <groundspeak:text encoded="False">My family and I attended this, and really enjoyed it! We will definitely be back for more! Thank you to Jordan Judt and the youth fishing instructors and everybody else who helped to organize it.</groundspeak:text>
        </groundspeak:log>
        <groundspeak:log id="1365185986">
          <groundspeak:date>2026-06-04T03:00:52Z</groundspeak:date>
          <groundspeak:type>Attended</groundspeak:type>
          <groundspeak:finder id="55559046">Hall9093</groundspeak:finder>
          <groundspeak:text encoded="False">Went on our first geocaching adventure</groundspeak:text>
        </groundspeak:log>
        <groundspeak:log id="1363751265">
          <groundspeak:date>2026-05-26T19:37:21Z</groundspeak:date>
          <groundspeak:type>Will Attend</groundspeak:type>
          <groundspeak:finder id="312341">Lovebug Family</groundspeak:finder>
          <groundspeak:text encoded="False">Will be there</groundspeak:text>
        </groundspeak:log>
        <groundspeak:log id="1360306453">

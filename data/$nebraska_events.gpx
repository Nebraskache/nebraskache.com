        <groundspeak:log id="1362501752">
          <groundspeak:date>2026-05-20T19:00:00Z</groundspeak:date>
          <groundspeak:type>Attended</groundspeak:type>
          <groundspeak:finder id="2120368">jenny08_1015</groundspeak:finder>
          <groundspeak:text encoded="False">It was nice to try a new and healthy place! TFTC</groundspeak:text>

        <groundspeak:attribute id="41" inc="1">Stroller accessible</groundspeak:attribute>
        <groundspeak:attribute id="1" inc="0">Dogs</groundspeak:attribute>
        <groundspeak:attribute id="25" inc="1">Parking nearby</groundspeak:attribute>
        <groundspeak:attribute id="32" inc="1">Bicycles</groundspeak:attribute>
        <groundspeak:attribute id="63" inc="1">Recommended for tourists</groundspeak:attribute>
        <groundspeak:attribute id="28" inc="1">Public restrooms nearby</groundspeak:attribute>
        <groundspeak:attribute id="59" inc="1">Food nearby</groundspeak:attribute>
        <groundspeak:attribute id="27" inc="1">Drinking water nearby</groundspeak:attribute>
        <groundspeak:attribute id="26" inc="1">Public transportation nearby</groundspeak:attribute>
        <groundspeak:attribute id="33" inc="1">Motorcycles</groundspeak:attribute>
        <groundspeak:attribute id="58" inc="1">Fuel nearby</groundspeak:attribute>
        <groundspeak:attribute id="29" inc="1">Telephone nearby</groundspeak:attribute>
      </groundspeak:attributes>
      <groundspeak:difficulty>1.0</groundspeak:difficulty>
      <groundspeak:terrain>1.0</groundspeak:terrain>
      <groundspeak:country>United States</groundspeak:country>
      <groundspeak:state>Nebraska</groundspeak:state>
      <groundspeak:short_description html="True">&lt;b&gt;20 May 2026, 17:45 - 19:45&lt;/b&gt;</groundspeak:short_description>
      <groundspeak:long_description html="True">&lt;p&gt;April showers bring...May flowers!  We still need more showers around here tho!&lt;/p&gt;

&lt;p&gt;An ongoing monthly Geocaching Dinner Event in Lincoln, open to everyone, especially good for geocachers new to the game.  It&amp;#39;s a great way to get tips and tricks, or help.&lt;/p&gt;

&lt;p&gt;Local and out-of-town geocachers are welcome and encouraged to attend. No 4-legged cachers here, sorry. Unless it&amp;#39;s a service dog, then that&amp;#39;s okay.&lt;/p&gt;

&lt;p&gt;No purchase is required to attend this event.&lt;/p&gt;

&lt;p&gt;Come join us for a nice suppertime get-together. This will be a great opportunity to plan a weekend geocaching trip with other cachers, ask for help on those caches or puzzle caches that are driving you crazy, trade/share Travel Bugs and/or other trackable items, or just have a nice dinner and trade geocaching stories or talk about whatever.&lt;/p&gt;

&lt;p&gt;&lt;strong&gt;Location: The Eatery, 2548 S. 48th Street, Lincoln&lt;br /&gt;
Date: Wednesday, May 20th&lt;br /&gt;
Start Time: 5:45 pm / End Time: 7:45 pm (end time varies, but restaurant closes at 8:00)&lt;/strong&gt;&lt;/p&gt;

&lt;p&gt;We will have the party room, so if you’ll please log a Will Attend I can tell them an approximate number to expect they will be sure to have appropriate staff on hand to take care of us!&lt;/p&gt;

&lt;p&gt; &lt;/p&gt;

&lt;p&gt; &lt;/p&gt;

&lt;p style="text-align:center;"&gt;&lt;a href="http://nebraskache.com/"&gt;&lt;img height="112" src="https://img.geocaching.com/9102f957-c986-41b5-acdb-a076bd017129.jpg" width="224" /&gt;&lt;/a&gt;&lt;/p&gt;

&lt;p style="text-align:center;"&gt;&lt;a href="http://nebraskache.com/"&gt;Hosted By A Nebraskache Member&lt;/a&gt;&lt;/p&gt;

&lt;p style="text-align:center;"&gt;&lt;a href="https://www.facebook.com/groups/107321656812/"&gt;&lt;img height="68" src="https://s3.amazonaws.com/gs-geo-images/19b6196d-f1d8-431b-9201-f4069d107ada_l.png" width="213" /&gt;&lt;/a&gt;&lt;/p&gt;

&lt;p style="text-align:center;"&gt;&lt;a href="http://nebraskache.com/"&gt;Hosted By A Nebraskache Member&lt;/a&gt;&lt;/p&gt;
</groundspeak:long_description>
      <groundspeak:encoded_hints>In the party room!</groundspeak:encoded_hints>

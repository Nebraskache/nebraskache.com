          <groundspeak:text encoded="False">Published</groundspeak:text>
        </groundspeak:log>
      </groundspeak:logs>
    </groundspeak:cache>
  </wpt>
  <wpt lat="40.774105" lon="-97.049303">
    <time>2026-08-04T17:45:00</time>
    <name>GCBTH9P</name>
    <desc>Diners and Dives # 92 by starsharon + Hubbie, Event Cache (1.0/1.0)</desc>
    <url>https://coord.info/GCBTH9P</url>
    <urlname>Diners and Dives # 92</urlname>
    <sym>Geocache</sym>
    <type>Geocache|Event Cache</type>
    <groundspeak:cache id="10509024" archived="False" available="True" xmlns:groundspeak="http://www.groundspeak.com/cache/1/0/1">
      <groundspeak:name>Diners and Dives # 92</groundspeak:name>
      <groundspeak:placed_by>starsharon and peteach!</groundspeak:placed_by>
      <groundspeak:owner id="1411659">starsharon + Hubbie</groundspeak:owner>
      <groundspeak:type>Event Cache</groundspeak:type>
      <groundspeak:container>Other</groundspeak:container>
      <groundspeak:attributes>
        <groundspeak:attribute id="24" inc="1">Wheelchair accessible</groundspeak:attribute>
        <groundspeak:attribute id="63" inc="1">Recommended for tourists</groundspeak:attribute>
        <groundspeak:attribute id="28" inc="1">Public restrooms nearby</groundspeak:attribute>
        <groundspeak:attribute id="59" inc="1">Food nearby</groundspeak:attribute>
        <groundspeak:attribute id="27" inc="1">Drinking water nearby</groundspeak:attribute>
        <groundspeak:attribute id="58" inc="1">Fuel nearby</groundspeak:attribute>
      </groundspeak:attributes>
      <groundspeak:difficulty>1.0</groundspeak:difficulty>
      <groundspeak:terrain>1.0</groundspeak:terrain>
      <groundspeak:country>United States</groundspeak:country>
      <groundspeak:state>Nebraska</groundspeak:state>
      <groundspeak:short_description html="True">&lt;b&gt;04 August 2026, 17:45 - 19:45&lt;/b&gt;</groundspeak:short_description>
      <groundspeak:long_description html="True">&lt;p&gt;Please join starsharon and peteach! for a progressive supper at different Diners &amp;amp; Dives in or near Lincoln and beyond. &amp;nbsp;We will rotate host duties every month.&amp;nbsp;&amp;nbsp;&lt;/p&gt;

&lt;h2&gt;Location for Tuesday, August 4, 2026:&amp;nbsp;&lt;/h2&gt;

&lt;h2&gt;Pizza Kitchen, 411 1st St. Milford, NE.&amp;nbsp;&amp;nbsp;&lt;/h2&gt;

&lt;p&gt;Please provide a &amp;#39;Will Attend&amp;#39; log so we can get a head count for our selected location of the month.&lt;/p&gt;

&lt;p&gt;Connect with other geocachers to ask for a tip or two on your caches without a &amp;#39;SMILEY&amp;#39;, trade/share travel bugs or just enjoy the company of fellow geocachers.&lt;/p&gt;

&lt;p&gt;No purchase is necessary to attend the event&lt;/p&gt;

&lt;p&gt;We hope to see you there. &amp;nbsp;A recurring monthly Geocaching Event in Lincoln and occasionally in the surrounding area that is open to everyone. Local and out-of-town geocachers are welcome and encouraged to attend.&lt;/p&gt;

&lt;p&gt;&amp;nbsp;&lt;/p&gt;

&lt;p&gt;&lt;a href="http://nebraskache.com/"&gt;&lt;img height="95" src="https://img.geocaching.com/9102f957-c986-41b5-acdb-a076bd017129.jpg" width="187" /&gt;&lt;/a&gt;&lt;/p&gt;

&lt;p&gt;&lt;a href="http://nebraskache.com/"&gt;Hosted By A Nebraskache Member&lt;/a&gt;&lt;/p&gt;

&lt;p&gt;&lt;a href="https://www.facebook.com/groups/107321656812/"&gt;&lt;img height="58" src="https://s3.amazonaws.com/gs-geo-images/19b6196d-f1d8-431b-9201-f4069d107ada_l.png" width="183" /&gt;&lt;/a&gt;&lt;/p&gt;

&lt;p&gt;As the geocache owner, I ensure that this links to a local geocaching group that is active in the community and contributing to geocaching in positive ways. This link has not been checked by Geocaching HQ or by the reviewer.&lt;/p&gt;
</groundspeak:long_description>

          <groundspeak:finder id="1411659">starsharon + Hubbie</groundspeak:finder>
          <groundspeak:text encoded="False">We always enjoy coming to this event. I'd give you a favorite if I could!!</groundspeak:text>
        </groundspeak:log>
        <groundspeak:log id="1369033774">
          <groundspeak:date>2026-06-27T20:08:35Z</groundspeak:date>
          <groundspeak:type>Attended</groundspeak:type>
          <groundspeak:finder id="1648992">tom57105</groundspeak:finder>
          <groundspeak:text encoded="False">Attended with b e e h 56 for our geocache of the day.  Thanks for this geocache event.</groundspeak:text>
        </groundspeak:log>
        <groundspeak:log id="1369023471">
          <groundspeak:date>2026-06-27T19:02:34Z</groundspeak:date>
          <groundspeak:type>Attended</groundspeak:type>
          <groundspeak:finder id="5787200">peteach!</groundspeak:finder>
          <groundspeak:text encoded="False">Such a fun group!
Thank you so much for all that you do for this event and ALL THE CACHES!!

  <wpt lat="40.596167" lon="-98.42535">
    <time>2026-03-14T09:00:00</time>
    <name>GCBJZ3P</name>
    <desc>Breakfast in the Tri Cites Hastings March 2026 by Contryguy, Event Cache (1.0/1.0)</desc>
    <url>https://coord.info/GCBJZ3P</url>
    <urlname>Breakfast in the Tri Cites Hastings March 2026</urlname>
    <sym>Geocache</sym>
    <type>Geocache|Event Cache</type>
    <groundspeak:cache id="10312794" archived="False" available="True" xmlns:groundspeak="http://www.groundspeak.com/cache/1/0/1">
      <groundspeak:name>Breakfast in the Tri Cites Hastings March 2026</groundspeak:name>
      <groundspeak:placed_by>Contryguy and negrant</groundspeak:placed_by>
      <groundspeak:owner id="115507">Contryguy</groundspeak:owner>
      <groundspeak:type>Event Cache</groundspeak:type>
      <groundspeak:container>Other</groundspeak:container>
      <groundspeak:attributes>
        <groundspeak:attribute id="24" inc="1">Wheelchair accessible</groundspeak:attribute>
      </groundspeak:attributes>
      <groundspeak:difficulty>1.0</groundspeak:difficulty>
      <groundspeak:terrain>1.0</groundspeak:terrain>
      <groundspeak:country>United States</groundspeak:country>
      <groundspeak:state>Nebraska</groundspeak:state>
      <groundspeak:short_description html="True">&lt;b&gt;14 March 2026, 09:00 - 10:00&lt;/b&gt;</groundspeak:short_description>
      <groundspeak:long_description html="True">&lt;p&gt;&lt;strong&gt;Important Announcement - Please log your will attend with number that will be in your party as this place sometimes gets very crowded and you may not be able to sit with our group if we don&amp;#39;t have an accurate count of those attending.&lt;/strong&gt;&lt;/p&gt;

&lt;p&gt;Come share your stories and enjoy some comaraderie with your fellow Geocachers. You might even get some help with that hard hide or puzzle.&lt;/p&gt;

&lt;p&gt;&lt;span class="marker"&gt;&lt;big&gt;&lt;span style="background-color:#ffffff;"&gt;Where: Sunflower Kitchen&lt;/span&gt;&lt;/big&gt;&lt;br /&gt;
&lt;span style="color:#000000;font-family:Roboto,Arial,sans-serif;font-size:14px;"&gt;&lt;span style="background-color:#ffffff;"&gt;1105 Theatre Dr ste 101&lt;/span&gt;&lt;/span&gt;&lt;br /&gt;
&lt;span style="color:#000000;font-family:Roboto,Arial,sans-serif;font-size:14px;"&gt;&lt;span style="background-color:#ffffff;"&gt;Hastings, NE 68901&lt;/span&gt;&lt;/span&gt;&lt;br /&gt;
&lt;span style="background-color:#ffffff;"&gt;Date: March 14, 2026&lt;/span&gt;&lt;br /&gt;
&lt;span style="background-color:#ffffff;"&gt;Time: 9:00 A.M. - 10:00ish A.M.&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;All ages and all cachers are invited. You can eat. You can drink. You can eat and drink. You can do neither and just show up to chat (no purchase necessary to attend). There is no meeting or agenda - just come and visit and do some geo-socializing with other geocachers. Hope to see you there! Please bring your coins and TBs for discovery, and for everyone else to enjoy!!&lt;/p&gt;

&lt;p&gt; &lt;/p&gt;

&lt;div style="text-align:center;"&gt;&lt;a href="http://NEbraskache.com"&gt;&lt;img height="112" src="https://img.geocaching.com:443/9102f957-c986-41b5-acdb-a076bd017129.jpg" width="224" /&gt;&lt;/a&gt;&lt;/div&gt;

&lt;p&gt; &lt;/p&gt;

&lt;p style="text-align:center;"&gt;&lt;a href="http://nebraskache.com/" style="margin:0px;padding:0px;color:rgb(61, 118, 197);font-family:inherit;font-size:13.93px;font-style:normal;font-weight:400;text-decoration:none;vertical-align:baseline;"&gt;Hosted By Nebraskache Members&lt;/a&gt;&lt;/p&gt;

&lt;p style="margin-left:0px;margin-right:0px;text-align:center;"&gt;&lt;a href="https://www.facebook.com/groups/107321656812/" style="margin:0px;padding:0px;color:rgb(61, 118, 197);font-family:inherit;font-size:13.93px;font-style:normal;font-weight:400;text-decoration:none;vertical-align:baseline;"&gt;&lt;img src="https://s3.amazonaws.com/gs-geo-images/19b6196d-f1d8-431b-9201-f4069d107ada_l.png" style="height:64px;width:210px;" /&gt;&lt;/a&gt;&lt;/p&gt;

&lt;p style="margin-left:0px;margin-right:0px;text-align:center;"&gt;As the event owner, I ensure that these links to a local geocaching group that is active in the community and contributing to geocaching in positive ways. This link has not been checked by Geocaching HQ or by the reviewer.&lt;/p&gt;

&lt;p&gt; &lt;/p&gt;
</groundspeak:long_description>

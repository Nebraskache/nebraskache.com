  <wpt lat="42.239" lon="-97.006917">
    <time>2026-06-06T11:30:00</time>
    <name>GCBQFA8</name>
    <desc>Lunch &amp; Log @ Sunnyview Park by CRVonFange, Event Cache (1.0/1.0)</desc>
    <url>https://coord.info/GCBQFA8</url>
    <urlname>Lunch &amp; Log @ Sunnyview Park</urlname>
    <sym>Geocache</sym>
    <type>Geocache|Event Cache</type>
    <groundspeak:cache id="10447537" archived="False" available="True" xmlns:groundspeak="http://www.groundspeak.com/cache/1/0/1">
      <groundspeak:name>Lunch &amp; Log @ Sunnyview Park</groundspeak:name>
      <groundspeak:placed_by>The Von Fanges</groundspeak:placed_by>
      <groundspeak:owner id="20507951">CRVonFange</groundspeak:owner>
      <groundspeak:type>Event Cache</groundspeak:type>
      <groundspeak:container>Other</groundspeak:container>
      <groundspeak:attributes>
        <groundspeak:attribute id="24" inc="1">Wheelchair accessible</groundspeak:attribute>
        <groundspeak:attribute id="6" inc="1">Recommended for kids</groundspeak:attribute>
        <groundspeak:attribute id="8" inc="1">Scenic view</groundspeak:attribute>
        <groundspeak:attribute id="25" inc="1">Parking nearby</groundspeak:attribute>
        <groundspeak:attribute id="32" inc="1">Bicycles</groundspeak:attribute>
        <groundspeak:attribute id="55" inc="1">Short hike (&lt;1 km)</groundspeak:attribute>
        <groundspeak:attribute id="66" inc="1">Teamwork cache</groundspeak:attribute>
        <groundspeak:attribute id="63" inc="1">Recommended for tourists</groundspeak:attribute>
        <groundspeak:attribute id="30" inc="1">Picnic tables nearby</groundspeak:attribute>
        <groundspeak:attribute id="28" inc="1">Public restrooms nearby</groundspeak:attribute>
        <groundspeak:attribute id="27" inc="1">Drinking water nearby</groundspeak:attribute>
        <groundspeak:attribute id="17" inc="0">Poisonous plants</groundspeak:attribute>
      </groundspeak:attributes>
      <groundspeak:difficulty>1.0</groundspeak:difficulty>
      <groundspeak:terrain>1.0</groundspeak:terrain>
      <groundspeak:country>United States</groundspeak:country>
      <groundspeak:state>Nebraska</groundspeak:state>
      <groundspeak:short_description html="True">&lt;b&gt;06 June 2026, 11:30 - 13:00&lt;/b&gt;</groundspeak:short_description>
      <groundspeak:long_description html="True">&lt;p&gt;&lt;span style="font-size:18px;"&gt;&lt;span style="font-family:Arial,Helvetica,sans-serif;"&gt;Calling all local and area geocachers! &lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-family:Arial,Helvetica,sans-serif;font-size:18px;"&gt;It is high time for another geocaching event in Wayne. &lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-family:Arial,Helvetica,sans-serif;font-size:18px;"&gt;Let&amp;#39;s get outside, enjoy the summer weather, and swap stories.&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-family:Arial,Helvetica,sans-serif;font-size:18px;"&gt;Join us at Sunnyview Park for a casual lunchtime meet-and-greet. Whether you are looking for your first smiley or closing in on a milestone, come grab a spot under the pavilion, break out your favorite picnic lunch, and catch up with fellow cachers.&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:20px;"&gt;&lt;strong&gt;Event Details &lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;strong&gt;&lt;!--TgQPHd|[]--&gt;&lt;/strong&gt;&lt;!--TgQPHd|[]--&gt;&lt;/p&gt;

&lt;p style="margin-left:40px;"&gt;&lt;span style="font-size:18px;"&gt;&lt;span style="font-family:Arial,Helvetica,sans-serif;"&gt;&lt;strong&gt;When:&lt;!--TgQPHd|[]--&gt;&lt;/strong&gt; Saturday, 6 June 2026&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p style="margin-left:40px;"&gt;&lt;span style="font-size:18px;"&gt;&lt;span style="font-family:Arial,Helvetica,sans-serif;"&gt;&lt;strong&gt;Time:&lt;/strong&gt; 11:30 AM - 1:00 PM&lt;/span&gt;&lt;/span&gt;&lt;!--TgQPHd|[]--&gt;&lt;!--TgQPHd|[]--&gt;&lt;/p&gt;

&lt;p style="margin-left:40px;"&gt;&lt;span style="font-size:18px;"&gt;&lt;span style="font-family:Arial,Helvetica,sans-serif;"&gt;&lt;strong&gt;Where:&lt;!--TgQPHd|[]--&gt;&lt;/strong&gt; Sunnyview Park @ 10th &amp;amp; Providence Road (curbside parking to picnic shelter)&lt;/span&gt;&lt;/span&gt;&lt;!--TgQPHd|[]--&gt;&lt;!--TgQPHd|[]--&gt;&lt;/p&gt;

&lt;p style="margin-left:40px;"&gt;&lt;span style="font-size:18px;"&gt;&lt;span style="font-family:Arial,Helvetica,sans-serif;"&gt;&lt;strong&gt;Pack:&lt;!--TgQPHd|[]--&gt;&lt;/strong&gt; your own picnic lunch or grab take out from one of the local fast food restaurants (McDonalds, Runza, Subway, Udder Delights, Jimmy Johns, and DQ can all be found along 7th Street)&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p style="margin-left:40px;"&gt;&lt;span style="font-size:18px;"&gt;&lt;span style="font-family:Arial,Helvetica,sans-serif;"&gt;&lt;strong&gt;Bring:&lt;/strong&gt; trackables and stories to share/swap along with your favorite geocaching pen to sign local logbooks&lt;/span&gt;&lt;/span&gt;&lt;!--TgQPHd|[]--&gt;&lt;!--TgQPHd|[]--&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:20px;"&gt;&lt;strong&gt;The Agenda:&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;strong&gt;&lt;!--TgQPHd|[]--&gt;&lt;/strong&gt;&lt;/p&gt;

&lt;p style="margin-left:40px;"&gt;&lt;span style="font-size:18px;"&gt;&lt;span style="font-family:Arial,Helvetica,sans-serif;"&gt;&lt;strong&gt;11:30 PM:&lt;!--TgQPHd|[]--&gt;&lt;/strong&gt; Meet, eat and socialize at the picnic tables in the shelter at the posted coordinates. There will be an official logbook for you to sign! &lt;/span&gt;&lt;/span&gt;&lt;!--TgQPHd|[]--&gt;&lt;!--TgQPHd|[]--&gt;&lt;/p&gt;

&lt;p style="margin-left:40px;"&gt;&lt;span style="font-size:18px;"&gt;&lt;span style="font-family:Arial,Helvetica,sans-serif;"&gt;&lt;strong&gt;1:00 PM:&lt;!--TgQPHd|[]--&gt;&lt;/strong&gt; Team up for some afternoon caching! Hopefully 10 to 12 new local caches will publish while we are eating lunch.&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:20px;"&gt;&lt;strong&gt;Important Notes:&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;strong&gt;&lt;!--TgQPHd|[]--&gt;&lt;/strong&gt;&lt;!--TgQPHd|[]--&gt;&lt;/p&gt;

&lt;p style="margin-left:40px;"&gt;&lt;span style="font-size:18px;"&gt;&lt;span style="font-family:Arial,Helvetica,sans-serif;"&gt;Please post your &lt;strong&gt;will attend&lt;/strong&gt;, something I am not so good about doing, so that I know about how many people to expect.&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p style="margin-left:40px;"&gt;&lt;span style="font-size:18px;"&gt;&lt;span style="font-family:Arial,Helvetica,sans-serif;"&gt;In the event that another group is using the picnic shelter, I will post an announcement about an alternate picnic shelter along with the name and cross streets for the new park.&lt;/span&gt;&lt;/span&gt;&lt;!--TgQPHd|[]--&gt;&lt;!--TgQPHd|[]--&gt;&lt;/p&gt;

&lt;p style="margin-left:40px;"&gt;&lt;span style="font-size:18px;"&gt;&lt;span style="font-family:Arial,Helvetica,sans-serif;"&gt;Restrooms and drinking fountain are available in the park, but you will need to bring your own lunch and drink.&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;
</groundspeak:long_description>

          <groundspeak:finder id="3067478">JavaJudt</groundspeak:finder>
          <groundspeak:text encoded="False">Looking forward to presenting!</groundspeak:text>
        </groundspeak:log>
      </groundspeak:logs>
    </groundspeak:cache>
  </wpt>
  <wpt lat="42.041184" lon="-97.440097">
    <time>2026-05-30T11:30:00</time>
    <name>GCBH9TA</name>
    <desc>Picnic! Join Us for a Cup of Joe - May 2026 by JavaJudt, Event Cache (1.0/1.5)</desc>
    <url>https://coord.info/GCBH9TA</url>
    <urlname>Picnic! Join Us for a Cup of Joe - May 2026</urlname>
    <sym>Geocache</sym>
    <type>Geocache|Event Cache</type>
    <groundspeak:cache id="10263492" archived="False" available="True" xmlns:groundspeak="http://www.groundspeak.com/cache/1/0/1">
      <groundspeak:name>Picnic! Join Us for a Cup of Joe - May 2026</groundspeak:name>
      <groundspeak:placed_by>Northeast Nebraska Geocachers</groundspeak:placed_by>
      <groundspeak:owner id="3067478">JavaJudt</groundspeak:owner>
      <groundspeak:type>Event Cache</groundspeak:type>
      <groundspeak:container>Other</groundspeak:container>
      <groundspeak:attributes>
        <groundspeak:attribute id="6" inc="1">Recommended for kids</groundspeak:attribute>
        <groundspeak:attribute id="41" inc="1">Stroller accessible</groundspeak:attribute>
        <groundspeak:attribute id="1" inc="0">Dogs</groundspeak:attribute>
        <groundspeak:attribute id="32" inc="1">Bicycles</groundspeak:attribute>
        <groundspeak:attribute id="9" inc="0">Significant hike</groundspeak:attribute>
        <groundspeak:attribute id="63" inc="1">Recommended for tourists</groundspeak:attribute>
        <groundspeak:attribute id="30" inc="1">Picnic tables nearby</groundspeak:attribute>
        <groundspeak:attribute id="28" inc="1">Public restrooms nearby</groundspeak:attribute>
        <groundspeak:attribute id="59" inc="1">Food nearby</groundspeak:attribute>
        <groundspeak:attribute id="27" inc="1">Drinking water nearby</groundspeak:attribute>
        <groundspeak:attribute id="33" inc="1">Motorcycles</groundspeak:attribute>
        <groundspeak:attribute id="37" inc="0">Horses</groundspeak:attribute>
        <groundspeak:attribute id="62" inc="0">Seasonal access</groundspeak:attribute>
        <groundspeak:attribute id="64" inc="0">Tree climbing required</groundspeak:attribute>
      </groundspeak:attributes>
      <groundspeak:difficulty>1.0</groundspeak:difficulty>
      <groundspeak:terrain>1.5</groundspeak:terrain>
      <groundspeak:country>United States</groundspeak:country>
      <groundspeak:state>Nebraska</groundspeak:state>
      <groundspeak:short_description html="True">&lt;b&gt;30 May 2026, 11:30 - 13:00&lt;/b&gt;</groundspeak:short_description>
      <groundspeak:long_description html="True">&lt;h1 style="text-align:center;"&gt;&lt;span style="color:#8e44ad;"&gt;Come join the Northeast Nebraska Geocachers for a Cup of Joe Picnic&lt;/span&gt;&lt;/h1&gt;

&lt;p&gt; &lt;/p&gt;

&lt;h1 style="text-align:center;"&gt;&lt;span style="color:#8e44ad;"&gt;May 2025&lt;/span&gt;&lt;/h1&gt;

&lt;p&gt; &lt;/p&gt;

&lt;p style="text-align:center;"&gt;&lt;img src="https://s3.amazonaws.com/gs-geo-images/f35dd082-e8d1-4243-bc06-d60895ee5c45_l.jpg" width="350" /&gt;&lt;/p&gt;

&lt;h3 style="text-align:center;"&gt; &lt;/h3&gt;

&lt;p style="text-align:center;"&gt;Please come and “Join Us for a Cup of Joe” to share caching adventures, misadventures, and what ever else you care to share. Whether you are a caching veteran or are new to the madness, bring your stories, questions, and expertise, and let&amp;#39;s have some fun!&lt;/p&gt;

&lt;p style="text-align:center;"&gt;This is a monthly recurring event in Norfolk. The event is typically held mid-late morning on the last Saturday of the month, and rotates around to various eateries in town. Events are a great way to meet other geocachers, and if you are new, to have your questions answered. Come on out, we don&amp;#39;t bite!&lt;/p&gt;

&lt;p style="text-align:center;"&gt;&lt;span style="color:#660033;"&gt;With the weather warming up, let&amp;#39;s have a picnic! Meet at Skyview Lake at the east parking area. (Enter at 18th Street and Maple Avenue.) We&amp;#39;ll be grilling burgers and hotdogs. Bring a side or dessert to share, and bring your own beverage. The event will start at &lt;/span&gt;&lt;span style="color:#e74c3c;"&gt;11:30 am&lt;/span&gt;&lt;span style="color:#660033;"&gt; with grilling soon to follow. The official event will last until &lt;/span&gt;&lt;span style="color:#e74c3c;"&gt;1:00 pm&lt;/span&gt;&lt;span style="color:#660033;"&gt;, but feel free to hang out as long as you&amp;#39;d like!&lt;/span&gt;&lt;/p&gt;

&lt;p style="text-align:center;"&gt;&lt;span style="color:#660033;"&gt;We&amp;#39;ll be watching the forecast ahead of time. In the event of incliment weather, we&amp;#39;ll post an announcement on the event page for a change of location. Make sure to get your Will Attend in, or place the event on your watchlist, to get all announcement notifications!&lt;/span&gt;&lt;/p&gt;

&lt;p style="text-align:center;"&gt;Skyview Lake offers a playground, a full disc golf course, and of course plenty of geocaching! Fishing is also permitted at the lake. The 1.8 mile trail around the lake is completely paved, though there are some steep hills in places.&lt;/p&gt;

&lt;p style="text-align:center;"&gt;Please try to let us know in advance if you plan to be there by posting a &amp;quot;Will Attend&amp;quot;. This helps us plan accordingly, but feel free to &amp;quot;just show up&amp;quot; as well! We&amp;#39;ll have a chair for you.&lt;/p&gt;

&lt;p style="text-align:center;"&gt; &lt;/p&gt;

&lt;h2 style="text-align:center;"&gt;&lt;span style="color:#c0392b;"&gt;Hope to see you there!&lt;/span&gt;&lt;/h2&gt;

&lt;p style="text-align:center;"&gt; &lt;/p&gt;

&lt;p style="text-align:center;"&gt;&lt;img alt="Nebraskache Logo" src="https://img.geocaching.com/02df206f-732a-4144-9c3d-582344cf4638.jpg" style="height:95px;width:190px;" /&gt;&lt;/p&gt;

&lt;p style="text-align:center;"&gt; &lt;/p&gt;
&lt;p&gt;Additional Waypoints&lt;/p&gt;01BH9TA - Parking&lt;br /&gt;N 42° 02.501 W 097° 26.410&lt;br /&gt;&lt;br /&gt;02BH9TA - Park Entrance&lt;br /&gt;N 42° 02.393 W 097° 26.050&lt;br /&gt;&lt;br /&gt;</groundspeak:long_description>
      <groundspeak:encoded_hints>
      </groundspeak:encoded_hints>

    <url>https://coord.info/GCBJNMY</url>
    <urlname>March Geo Breakfast</urlname>
    <sym>Geocache</sym>
    <type>Geocache|Event Cache</type>
    <groundspeak:cache id="10304679" archived="False" available="True" xmlns:groundspeak="http://www.groundspeak.com/cache/1/0/1">
      <groundspeak:name>March Geo Breakfast</groundspeak:name>
      <groundspeak:placed_by>Monty12</groundspeak:placed_by>
      <groundspeak:owner id="1253738">Monty12</groundspeak:owner>
      <groundspeak:type>Event Cache</groundspeak:type>
      <groundspeak:container>Other</groundspeak:container>
      <groundspeak:attributes>
        <groundspeak:attribute id="24" inc="1">Wheelchair accessible</groundspeak:attribute>
        <groundspeak:attribute id="25" inc="1">Parking nearby</groundspeak:attribute>
        <groundspeak:attribute id="58" inc="1">Fuel nearby</groundspeak:attribute>
      </groundspeak:attributes>
      <groundspeak:difficulty>1.0</groundspeak:difficulty>
      <groundspeak:terrain>1.0</groundspeak:terrain>
      <groundspeak:country>United States</groundspeak:country>
      <groundspeak:state>Nebraska</groundspeak:state>
      <groundspeak:short_description html="True">&lt;b&gt;14 March 2026, 08:00 - 09:30&lt;/b&gt;</groundspeak:short_description>
      <groundspeak:long_description html="True">&lt;p&gt;&lt;span style="font-size:18px;"&gt;&lt;strong&gt;March 14th 0800-0930&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:20px;"&gt;Please join your fellow cachers for the monthly Deli Caching Breakfast.  This is a monthly event so you all know where to go.&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:20px;"&gt;The deli is wheelchair accessible and offers three options:&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:20px;"&gt;1.  a full breakfast and lunch menu&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:20px;"&gt;2.  purchase something (like a donut or yogurt) from the store and enjoy it at the event&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:20px;"&gt;3.  just join us for the fun.  No purchase is necessary to attend this event.&lt;/span&gt;&lt;/p&gt;
</groundspeak:long_description>

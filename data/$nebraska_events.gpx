      <groundspeak:long_description html="True">&lt;h1 style="text-align:center;"&gt;&lt;span style="color:#e67e22;"&gt;&lt;span style="font-size:48px;"&gt;&lt;u&gt;Here&amp;#39;s the scoop&lt;/u&gt;!   &lt;/span&gt;&lt;/span&gt;  &lt;/h1&gt;

&lt;p style="text-align:center;"&gt;&lt;span style="font-size:20px;"&gt;Come out for geocaching talk with fellow cachers before the&lt;/span&gt;&lt;/p&gt;

&lt;h1 style="text-align:center;"&gt;&lt;span style="color:#ffffff;"&gt;&lt;span style="font-size:48px;"&gt;&lt;span style="background-color:#336600;"&gt;23rd Annual Nebraskache Picnic&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/h1&gt;


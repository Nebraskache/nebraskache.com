      <groundspeak:short_description html="True">&lt;b&gt;11 April 2026, 08:00 - 09:30&lt;/b&gt;</groundspeak:short_description>
      <groundspeak:long_description html="True">&lt;p&gt;Please join your fellow cachers for the monthly HyVee Deli Caching Breakfast. Come enjoy a meal together or just swap stories and adventures from the trail.&lt;/p&gt;


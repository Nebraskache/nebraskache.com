        </groundspeak:log>
        <groundspeak:log id="1360022197">
          <groundspeak:date>2026-05-09T19:00:00Z</groundspeak:date>
          <groundspeak:type>Write note</groundspeak:type>
          <groundspeak:finder id="3067478">JavaJudt</groundspeak:finder>
          <groundspeak:text encoded="False">Unfortunately rescinding my Will Attend due to family in town this weekend and other goings-on.

*Hope to attend for at least some of the festivities!*</groundspeak:text>
        </groundspeak:log>
        <groundspeak:log id="1368878710">
          <groundspeak:date>2026-06-26T19:00:00Z</groundspeak:date>

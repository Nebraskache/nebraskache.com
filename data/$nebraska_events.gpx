    <time>2026-02-14T09:00:00</time>
    <name>GCBHH14</name>
    <desc>Breakfast in the Tri-Cities Grand Island by CRKAT, Event Cache (1.0/1.0)</desc>
    <url>https://coord.info/GCBHH14</url>
    <urlname>Breakfast in the Tri-Cities Grand Island</urlname>
    <sym>Geocache</sym>
    <type>Geocache|Event Cache</type>
    <groundspeak:cache id="10270430" archived="False" available="True" xmlns:groundspeak="http://www.groundspeak.com/cache/1/0/1">
      <groundspeak:name>Breakfast in the Tri-Cities Grand Island</groundspeak:name>
      <groundspeak:placed_by>CRKAT</groundspeak:placed_by>
      <groundspeak:owner id="2176584">CRKAT</groundspeak:owner>
      <groundspeak:type>Event Cache</groundspeak:type>
      <groundspeak:container>Other</groundspeak:container>
      <groundspeak:attributes>
        <groundspeak:attribute id="24" inc="1">Wheelchair accessible</groundspeak:attribute>
      </groundspeak:attributes>
      <groundspeak:difficulty>1.0</groundspeak:difficulty>
      <groundspeak:terrain>1.0</groundspeak:terrain>
      <groundspeak:country>United States</groundspeak:country>
      <groundspeak:state>Nebraska</groundspeak:state>
      <groundspeak:short_description html="True">&lt;b&gt;14 February 2026, 09:00 - 10:00&lt;/b&gt;</groundspeak:short_description>
      <groundspeak:long_description html="True">&lt;p&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="background-color:white;"&gt;&lt;span style="font-family:Calibri,sans-serif;"&gt;&lt;strong&gt;&lt;span style="font-size:10.5pt;"&gt;&lt;span style="background-color:white;"&gt;&lt;span style="font-family:&amp;amp;quot;"&gt;&lt;span style="color:#4a4a4a;"&gt;Come share your stories and enjoy some camaraderie with your fellow Geocachers.  You might even get some help with that hard hide or puzzle.&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="background-color:white;"&gt;&lt;span style="font-family:Calibri,sans-serif;"&gt;&lt;span style="font-size:12.0pt;"&gt;&lt;span style="background-color:white;"&gt;&lt;span style="font-family:&amp;amp;quot;"&gt;&lt;span style="color:#4a4a4a;"&gt;Where:  Tommy’s &lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;br /&gt;
&lt;span style="font-size:12.0pt;"&gt;&lt;span style="background-color:white;"&gt;&lt;span style="font-family:&amp;amp;quot;"&gt;&lt;span style="color:#4a4a4a;"&gt;               1325 South Locust&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;br /&gt;
&lt;span style="font-size:10.5pt;"&gt;&lt;span style="background-color:white;"&gt;&lt;span style="font-family:&amp;amp;quot;"&gt;&lt;span style="color:#4a4a4a;"&gt;                 Grand Island, NE&lt;br /&gt;
Date: February 14, 2026&lt;br /&gt;
Time: 9:00 A.M. - 10:00 AM ish&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="background-color:white;"&gt;&lt;span style="font-family:Calibri,sans-serif;"&gt;&lt;span style="font-size:10.5pt;"&gt;&lt;span style="background-color:white;"&gt;&lt;span style="font-family:&amp;amp;quot;"&gt;&lt;span style="color:#4a4a4a;"&gt;All ages and all cachers are invited. You can eat. You can drink. You can eat and drink. You can do neither and just show up to chat (no purchase necessary to attend).  There is no meeting or agenda - just come and visit and do some geo-socializing with other geocachers. Hope to see you there! Please bring your coins and TBs for discovery, and for everyone else to enjoy!!&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p style="text-align:center;"&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="background-color:white;"&gt;&lt;span style="font-family:Calibri,sans-serif;"&gt;&lt;strong&gt;&lt;span style="font-size:10.5pt;"&gt;&lt;span style="background-color:white;"&gt;&lt;span style="font-family:&amp;amp;quot;"&gt;&lt;span style="color:#4a4a4a;"&gt;Please post a will attend so I can give the restaurant an idea of how many people will be attending  &lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/strong&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p style="text-align:center;"&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="background-color:white;"&gt;&lt;span style="font-family:Calibri,sans-serif;"&gt;&lt;strong&gt;&lt;span style="font-size:10.5pt;"&gt;&lt;span style="background-color:white;"&gt;&lt;span style="font-family:&amp;amp;quot;"&gt;&lt;span style="color:#4a4a4a;"&gt;      &lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/strong&gt;&lt;span style="font-size:10.5pt;"&gt;&lt;span style="background-color:white;"&gt;&lt;span style="font-family:&amp;amp;quot;"&gt;&lt;span style="color:#4a4a4a;"&gt;&lt;img src="https://img.geocaching.com:443/00426daa-76b2-4d4b-a5e0-1868ba3ce227.png" /&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p style="text-align:center;"&gt;&lt;span style="font-size:11pt;"&gt;&lt;span style="background-color:white;"&gt;&lt;span style="font-family:Calibri,sans-serif;"&gt;&lt;span style="font-size:10.5pt;"&gt;&lt;span style="font-family:&amp;amp;quot;"&gt;&lt;span style="color:#4a4a4a;"&gt;&lt;a href="http://nebraskache.com/"&gt;&lt;span style="color:#3d76c5;"&gt;Placed By A Nebraskache Member&lt;/span&gt;&lt;/a&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;

&lt;p style="text-align:center;"&gt;&lt;br /&gt;
&lt;span style="font-size:11pt;"&gt;&lt;span style="background-color:white;"&gt;&lt;span style="font-family:Calibri,sans-serif;"&gt;&lt;span style="font-size:10.5pt;"&gt;&lt;span style="font-family:&amp;amp;quot;"&gt;&lt;span style="color:#4a4a4a;"&gt;As the event owner, I ensure that these links to a local geocaching group that is active in the community and contributing to geocaching in positive ways. This link has not been checked by Geocaching HQ or by the reviewer.&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/p&gt;
</groundspeak:long_description>
      <groundspeak:encoded_hints>
      </groundspeak:encoded_hints>

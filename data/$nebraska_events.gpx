  <wpt lat="40.757967" lon="-96.6426">
    <time>2026-04-07T17:45:00</time>
    <name>GCBKB3W</name>
    <desc>Diners and Dives #88 by starsharon + Hubbie, Event Cache (1.0/1.0)</desc>
    <url>https://coord.info/GCBKB3W</url>
    <urlname>Diners and Dives #88</urlname>
    <sym>Geocache</sym>
    <type>Geocache|Event Cache</type>
    <groundspeak:cache id="10324331" archived="False" available="True" xmlns:groundspeak="http://www.groundspeak.com/cache/1/0/1">
      <groundspeak:name>Diners and Dives #88</groundspeak:name>
      <groundspeak:placed_by>starsharon and peteach!</groundspeak:placed_by>
      <groundspeak:owner id="1411659">starsharon + Hubbie</groundspeak:owner>
      <groundspeak:type>Event Cache</groundspeak:type>
      <groundspeak:container>Other</groundspeak:container>
      <groundspeak:attributes>
        <groundspeak:attribute id="24" inc="1">Wheelchair accessible</groundspeak:attribute>
        <groundspeak:attribute id="63" inc="1">Recommended for tourists</groundspeak:attribute>
        <groundspeak:attribute id="28" inc="1">Public restrooms nearby</groundspeak:attribute>
        <groundspeak:attribute id="59" inc="1">Food nearby</groundspeak:attribute>
        <groundspeak:attribute id="27" inc="1">Drinking water nearby</groundspeak:attribute>
        <groundspeak:attribute id="33" inc="1">Motorcycles</groundspeak:attribute>
        <groundspeak:attribute id="58" inc="1">Fuel nearby</groundspeak:attribute>
        <groundspeak:attribute id="29" inc="1">Telephone nearby</groundspeak:attribute>
      </groundspeak:attributes>
      <groundspeak:difficulty>1.0</groundspeak:difficulty>
      <groundspeak:terrain>1.0</groundspeak:terrain>
      <groundspeak:country>United States</groundspeak:country>
      <groundspeak:state>Nebraska</groundspeak:state>
      <groundspeak:short_description html="True">&lt;b&gt;07 April 2026, 17:45 - 19:45&lt;/b&gt;</groundspeak:short_description>
      <groundspeak:long_description html="True">&lt;p&gt;Please join starsharon and peteach! for a progressive supper at different Diners &amp;amp; Dives in or near Lincoln and beyond.  We will rotate host duties every month.  &lt;/p&gt;

&lt;p&gt;&lt;br /&gt;
&lt;br /&gt;
&lt;strong&gt;Location for Tuesday April 7th, 2026&lt;/strong&gt;&lt;br /&gt;
&lt;br /&gt;
&lt;strong&gt;The Mettle Grill&lt;/strong&gt;&lt;/p&gt;

&lt;p&gt;&lt;strong&gt;5500 S 56th Street #8&lt;/strong&gt;&lt;/p&gt;

&lt;p&gt;&lt;strong&gt;Lincoln, NE&lt;/strong&gt;&lt;br /&gt;
&lt;br /&gt;
&lt;br /&gt;
Please provide a &amp;#39;Will Attend&amp;#39; log so we can get a head count for our selected location of the month.&lt;br /&gt;
&lt;br /&gt;
Connect with other geocachers to ask for a tip or two on your caches without a &amp;#39;SMILEY&amp;#39;, trade/share travel bugs or just enjoy the company of fellow geocachers.&lt;br /&gt;
&lt;br /&gt;
No purchase is necessary to attend the event&lt;br /&gt;
&lt;br /&gt;
We hope to see you there.  A recurring monthly Geocaching Event in Lincoln and occasionally in the surrounding area that is open to everyone.  Local and out-of-town geocachers are welcome and encouraged to attend.&lt;/p&gt;

&lt;p style="text-align:center;"&gt;&lt;a href="http://nebraskache.com/"&gt;&lt;img height="112" src="https://img.geocaching.com/9102f957-c986-41b5-acdb-a076bd017129.jpg" width="224" /&gt;&lt;/a&gt;&lt;/p&gt;

&lt;p style="text-align:center;"&gt;&lt;a href="http://nebraskache.com/"&gt;Placed By A Nebraskache Member&lt;/a&gt;&lt;/p&gt;

&lt;p style="text-align:center;"&gt;&lt;a href="https://www.facebook.com/groups/107321656812/"&gt;&lt;img height="69" src="https://s3.amazonaws.com/gs-geo-images/19b6196d-f1d8-431b-9201-f4069d107ada_l.png" width="221" /&gt;&lt;/a&gt;&lt;/p&gt;

&lt;p style="text-align:center;"&gt;&lt;br /&gt;
As the event owner, I ensure that these links to a local geocaching group that is active in the community and contributing to geocaching in positive ways. This link has not been checked by Geocaching HQ or by the reviewer.&lt;/p&gt;
</groundspeak:long_description>
